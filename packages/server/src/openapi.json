{
  "openapi": "3.0.3",
  "info": {
    "title": "ar.io Verify API",
    "description": "Cryptographic data verification and attestation for Arweave via ar.io gateways. Proves existence, authenticity, and authorship of any Arweave transaction including ANS-104 bundled data items.",
    "version": "0.1.0",
    "contact": {
      "name": "ar.io",
      "url": "https://ar.io"
    },
    "license": {
      "name": "AGPL-3.0",
      "url": "https://www.gnu.org/licenses/agpl-3.0.html"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Current server"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Liveness probe",
        "description": "Returns 200 as long as the process is running. Use as a Kubernetes-style livenessProbe. `gateway` is informational; a failing gateway does not make `/health` fail (use `/ready` for that).",
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "Process is alive",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "gateway": {
                      "type": "boolean",
                      "description": "Whether the ar.io gateway is reachable"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "summary": "Readiness probe",
        "description": "Returns 200 only if all critical dependencies (DB, gateway) are reachable. Returns 503 otherwise with a per-check breakdown. Use as a Kubernetes-style readinessProbe so traffic drains when a dependency is down.",
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "Ready to serve traffic",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ReadyResponse" } }
            }
          },
          "503": {
            "description": "Not ready — a dependency is unreachable",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ReadyResponse" } }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "summary": "Prometheus scrape endpoint",
        "description": "Returns metrics in Prometheus text-exposition format. Includes default node metrics under the `verify_` prefix plus domain counters, gauges, and histograms (`verify_jobs_created_total`, `verify_runs_total{status}`, `verify_tx_outcomes_total{outcome,cache_hit}`, `verify_gateway_requests_total`, `verify_gateway_queue_depth`, `verify_signing_enabled`, `verify_inflight_jobs`, `verify_run_duration_seconds`, `verify_http_requests_total{route,status_class}`, etc). No per-tenant labels — cardinality discipline. Restrict access at the proxy layer.",
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "Prometheus text-format metrics",
            "content": {
              "text/plain": { "schema": { "type": "string" } }
            }
          }
        }
      }
    },
    "/api": {
      "get": {
        "summary": "API info",
        "description": "Returns service metadata and available endpoints.",
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "API information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "version": { "type": "string" },
                    "description": { "type": "string" },
                    "endpoints": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/config": {
      "get": {
        "summary": "Runtime frontend configuration",
        "description": "Returns runtime config for browser clients, including the public gateway URL to use for image previews and raw data links.",
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "Runtime configuration",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "publicGatewayUrl": {
                      "type": "string",
                      "description": "Browser-reachable gateway URL (e.g. https://vilenarios.com)"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/verify": {
      "post": {
        "summary": "Verify a transaction",
        "description": "Runs the full verification pipeline: fetches data from the gateway, computes independent SHA-256 hash, verifies RSA-PSS/ED25519/ECDSA signature via deep hash, and produces a signed attestation. Results are cached.",
        "tags": ["Verification"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["txId"],
                "properties": {
                  "txId": {
                    "type": "string",
                    "pattern": "^[a-zA-Z0-9_-]{43}$",
                    "description": "Arweave transaction ID (43 base64url characters)",
                    "example": "WkaBoAfqfW2P4K2NO1SBDwhVsKQJSVTVEnaDvjoyZzA"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VerificationResult" }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Verification failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/verify/tx/{txId}": {
      "get": {
        "summary": "Get verification history for a transaction",
        "description": "Returns all cached verification results for a transaction ID, most recent first.",
        "tags": ["Verification"],
        "parameters": [
          {
            "name": "txId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "pattern": "^[a-zA-Z0-9_-]{43}$" },
            "description": "Arweave transaction ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Verification history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "txId": { "type": "string" },
                    "count": { "type": "integer" },
                    "results": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/VerificationResult" }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid transaction ID format",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/verify/{id}": {
      "get": {
        "summary": "Get a cached verification result",
        "description": "Retrieve a previously computed verification result by its verification ID.",
        "tags": ["Verification"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Verification ID (e.g., vrf_abc123...)"
          }
        ],
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VerificationResult" }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/verify/{id}/pdf": {
      "get": {
        "summary": "Download PDF attestation certificate",
        "description": "Generates a PDF certificate containing the verification results, evidence summary, cryptographic proof appendix, and gateway attestation (if signing key is configured).",
        "tags": ["Attestation"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Verification ID"
          }
        ],
        "responses": {
          "200": {
            "description": "PDF certificate",
            "content": {
              "application/pdf": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "PDF generation failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/verify/{id}/attestation": {
      "get": {
        "summary": "Get attestation for programmatic verification",
        "description": "Returns the attestation payload, signature, and operator public key. Third parties can verify by passing the canonical JSON payload (keys sorted alphabetically, no whitespace) to a standard RSA-PSS SHA-256 verifier with the operator's public key.",
        "tags": ["Attestation"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Verification ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Attestation data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AttestationResponse" }
              }
            }
          },
          "404": {
            "description": "Not found or no attestation available",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs": {
      "post": {
        "summary": "Create a verification job",
        "description": "Submit a list of transaction IDs for batch verification. Returns 202 with a job id; the job runs asynchronously. Honors the Idempotency-Key header per tenant — repeated POSTs with the same key return the same job id.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/TenantHeader" },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^[\\x21-\\x7E]{1,128}$",
              "maxLength": 128
            },
            "description": "Optional. Repeats with the same key (per tenant) return the original job id without enqueueing a duplicate. Printable ASCII, max 128 chars."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["txIds"],
                "properties": {
                  "txIds": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 50000,
                    "items": {
                      "type": "string",
                      "pattern": "^[A-Za-z0-9_-]{43}$"
                    },
                    "description": "Arweave transaction IDs (43-char base64url) to verify. Up to 50,000 per job; total request body is capped at 16 MB."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Job accepted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "jobId": { "type": "string", "example": "job_abc123def456gh" },
                    "status": { "type": "string", "example": "pending" },
                    "deduplicated": { "type": "boolean" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed. The `error` field is one of: `invalid_body` (txIds missing/malformed/over 50,000), `invalid_idempotency_key`, or `Invalid X-Tenant-Id format`.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "401": { "description": "Missing X-Tenant-Id header (production mode)" },
          "413": { "description": "Request body exceeds 16 MB" }
        }
      }
    },
    "/api/v1/jobs/{id}": {
      "get": {
        "summary": "Get job status",
        "description": "Returns job + latest run with counters and ETA. 404 if the job belongs to a different tenant — existence is not leaked.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/TenantHeader" },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Status snapshot",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/JobStatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/TenantInvalid" },
          "401": { "$ref": "#/components/responses/TenantMissing" },
          "404": { "description": "Job not found" }
        }
      },
      "delete": {
        "summary": "Cancel a job",
        "description": "Soft-cancel: marks status='cancelled'. The worker checks per-tx and exits cleanly; recorded results stay queryable.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/TenantHeader" },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Cancellation requested" },
          "400": { "$ref": "#/components/responses/TenantInvalid" },
          "401": { "$ref": "#/components/responses/TenantMissing" },
          "404": { "description": "Job not found" },
          "409": { "description": "Job already in a terminal status (completed/failed/cancelled)" }
        }
      }
    },
    "/api/v1/jobs/{id}/results": {
      "get": {
        "summary": "List per-tx outcomes for a job's latest run",
        "description": "Cursor-paginated. Each result includes a granular failureReason for tampered/unavailable outcomes — distinguish signature mismatch from gateway timeout etc.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/TenantHeader" },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          {
            "name": "cursor",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Cursor returned by previous page"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 500, "default": 100 }
          },
          {
            "name": "outcome",
            "in": "query",
            "schema": { "type": "string", "enum": ["verified", "tampered", "unavailable"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Page of per-tx outcomes",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/JobResultsPage" }
              }
            }
          },
          "400": {
            "description": "Invalid query parameter (`invalid_limit`, `invalid_outcome`) or tenant header.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "401": { "$ref": "#/components/responses/TenantMissing" },
          "404": { "description": "Job not found" }
        }
      }
    },
    "/api/v1/jobs/{id}/report": {
      "get": {
        "summary": "Get the signed verification bundle for a completed run",
        "description": "Primary artifact: a canonical-JSON, operator-signed verification bundle, machine-verifiable offline using only the operator's public key. Verifiers reconstruct the canonical JSON of the bundle minus the `signature` and `payloadHash` fields, recompute the SHA-256 to match `payloadHash`, and verify RSA-PSS-SHA256 of `signature` against the operator's public key.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/TenantHeader" },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Signed verification bundle (canonical JSON, byte-identical to what was signed)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VerificationBundleV1" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/TenantInvalid" },
          "401": { "$ref": "#/components/responses/TenantMissing" },
          "404": { "description": "Job not found, or no completed run yet" },
          "406": { "description": "PDF view requested but renderer not yet implemented" }
        }
      }
    },
    "/api/v1/jobs/events": {
      "get": {
        "summary": "Pull the tenant's event stream",
        "description": "Returns events emitted by completed/failed/cancelled runs, ordered by id ascending. Replaces push webhooks for the MVP — consumers poll with `since=<lastSeenEventId>` to advance.",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/TenantHeader" },
          {
            "name": "since",
            "in": "query",
            "schema": { "type": "integer", "minimum": 0 },
            "description": "Return events with id strictly greater than this value."
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 500, "default": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "Page of events",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/JobEventsPage" }
              }
            }
          },
          "400": {
            "description": "Invalid `since`, `limit`, or tenant header.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "401": { "$ref": "#/components/responses/TenantMissing" }
        }
      }
    }
  },
  "components": {
    "responses": {
      "TenantInvalid": {
        "description": "X-Tenant-Id is malformed (must match `^[A-Za-z0-9_.:-]{1,128}$`).",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "TenantMissing": {
        "description": "X-Tenant-Id header is required (in production). Whatever sits in front of verify is responsible for injecting it.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    },
    "parameters": {
      "TenantHeader": {
        "name": "X-Tenant-Id",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.:-]{1,128}$",
          "maxLength": 128
        },
        "description": "Opaque tenant identifier injected by whatever sits in front of verify (an API gateway, reverse proxy, etc). Verify treats the value as opaque — it is used purely as a partition key. A length+charset envelope is enforced to keep the value sane as a primary-key column. In NODE_ENV != 'production' this header is optional and a synthetic dev tenant is used."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      },
      "ReadyResponse": {
        "type": "object",
        "properties": {
          "ready": { "type": "boolean" },
          "checks": {
            "type": "object",
            "properties": {
              "db": { "type": "boolean" },
              "gateway": { "type": "boolean" },
              "signing": {
                "type": "boolean",
                "description": "Whether the operator signing wallet is loaded. Informational; not a readiness gate (the server runs without one for unsigned bundles)."
              }
            }
          }
        }
      },
      "VerificationResult": {
        "type": "object",
        "properties": {
          "verificationId": { "type": "string", "example": "vrf_abc123def456gh" },
          "timestamp": { "type": "string", "format": "date-time" },
          "txId": { "type": "string", "example": "WkaBoAfqfW2P4K2NO1SBDwhVsKQJSVTVEnaDvjoyZzA" },
          "level": {
            "type": "integer",
            "enum": [1, 2, 3],
            "description": "3=Signature verified, 2=Hash verified, 1=Existence only"
          },
          "existence": {
            "type": "object",
            "properties": {
              "status": { "type": "string", "enum": ["confirmed", "pending", "not_found"] },
              "blockHeight": { "type": "integer", "nullable": true },
              "blockTimestamp": { "type": "string", "format": "date-time", "nullable": true },
              "blockId": { "type": "string", "nullable": true }
            }
          },
          "authenticity": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": ["signature_verified", "hash_verified", "unverified"]
              },
              "signatureValid": { "type": "boolean", "nullable": true },
              "signatureSkipReason": { "type": "string", "nullable": true },
              "dataHash": {
                "type": "string",
                "nullable": true,
                "description": "SHA-256 of raw data (base64url)"
              },
              "gatewayHash": {
                "type": "string",
                "nullable": true,
                "description": "SHA-256 from gateway x-ar-io-digest header"
              },
              "hashMatch": { "type": "boolean", "nullable": true }
            }
          },
          "owner": {
            "type": "object",
            "properties": {
              "address": { "type": "string", "nullable": true },
              "publicKey": { "type": "string", "nullable": true },
              "addressVerified": { "type": "boolean", "nullable": true }
            }
          },
          "metadata": {
            "type": "object",
            "properties": {
              "dataSize": { "type": "integer", "nullable": true },
              "contentType": { "type": "string", "nullable": true },
              "tags": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "value": { "type": "string" }
                  }
                }
              }
            }
          },
          "bundle": {
            "type": "object",
            "properties": {
              "isBundled": { "type": "boolean" },
              "rootTransactionId": { "type": "string", "nullable": true }
            }
          },
          "gatewayAssessment": {
            "type": "object",
            "properties": {
              "verified": { "type": "boolean", "nullable": true },
              "stable": { "type": "boolean", "nullable": true },
              "trusted": { "type": "boolean", "nullable": true },
              "hops": { "type": "integer", "nullable": true }
            }
          },
          "attestation": {
            "nullable": true,
            "type": "object",
            "description": "Operator attestation. Null if no signing key configured.",
            "properties": {
              "operator": { "type": "string" },
              "gateway": { "type": "string" },
              "signature": { "type": "string", "description": "RSA-PSS signature (base64url)" },
              "payloadHash": {
                "type": "string",
                "description": "SHA-256 of canonical attestation payload"
              },
              "payload": {
                "type": "object",
                "description": "The canonical attestation payload that was signed"
              },
              "attestedAt": { "type": "string", "format": "date-time" }
            }
          },
          "links": {
            "type": "object",
            "properties": {
              "dashboard": { "type": "string", "nullable": true },
              "pdf": { "type": "string", "nullable": true },
              "rawData": { "type": "string", "nullable": true }
            }
          }
        }
      },
      "AttestationResponse": {
        "type": "object",
        "properties": {
          "operator": { "type": "string" },
          "gateway": { "type": "string" },
          "signature": { "type": "string", "description": "RSA-PSS signature (base64url)" },
          "payloadHash": { "type": "string" },
          "payload": { "type": "object", "description": "Canonical attestation payload" },
          "attestedAt": { "type": "string", "format": "date-time" },
          "operatorPublicKey": {
            "type": "string",
            "nullable": true,
            "description": "Operator's RSA public key (base64url n value)"
          }
        }
      },
      "JobStatusResponse": {
        "type": "object",
        "properties": {
          "job": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["pending", "running", "completed", "failed", "cancelled"]
              },
              "totalCount": { "type": "integer" },
              "createdAt": { "type": "integer", "description": "Epoch milliseconds" },
              "idempotencyKey": { "type": "string", "nullable": true }
            }
          },
          "run": {
            "nullable": true,
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["running", "completed", "failed", "cancelled"]
              },
              "startedAt": { "type": "integer" },
              "finishedAt": { "type": "integer", "nullable": true },
              "counters": {
                "type": "object",
                "properties": {
                  "verified": { "type": "integer" },
                  "tampered": { "type": "integer" },
                  "unavailable": { "type": "integer" },
                  "cacheHit": { "type": "integer" },
                  "bytesFetched": { "type": "integer" }
                }
              },
              "remaining": { "type": "integer" },
              "etaMs": {
                "type": "integer",
                "nullable": true,
                "description": "Estimated milliseconds remaining based on observed throughput; null if no progress yet."
              },
              "summaryBundleId": { "type": "string", "nullable": true }
            }
          }
        }
      },
      "JobResultsPage": {
        "type": "object",
        "properties": {
          "runId": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/JobResult" }
          },
          "nextCursor": { "type": "string", "nullable": true }
        }
      },
      "JobResult": {
        "type": "object",
        "properties": {
          "txId": { "type": "string" },
          "verificationId": { "type": "string", "nullable": true },
          "outcome": {
            "type": "string",
            "enum": ["verified", "tampered", "unavailable"]
          },
          "cacheHit": { "type": "boolean" },
          "failureReason": {
            "type": "string",
            "nullable": true,
            "enum": [
              "signature_mismatch",
              "tx_id_mismatch",
              "data_hash_mismatch",
              "gateway_timeout",
              "gateway_5xx",
              "gateway_404",
              "binary_header_unavailable",
              "data_too_large",
              "no_signature",
              "job_cancelled",
              "unknown"
            ]
          }
        }
      },
      "JobEventsPage": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/JobEvent" } },
          "nextCursor": { "type": "string", "nullable": true }
        }
      },
      "JobEvent": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "tenantId": { "type": "string" },
          "jobId": { "type": "string" },
          "runId": { "type": "string", "nullable": true },
          "type": {
            "type": "string",
            "enum": ["run.completed", "run.failed", "run.cancelled"]
          },
          "payload": { "type": "object" },
          "createdAt": { "type": "integer" }
        }
      },
      "VerificationBundleV1": {
        "type": "object",
        "description": "Canonical, operator-signed verification bundle. Verifiers re-serialize the bundle minus `signature` and `payloadHash`, recompute SHA-256 to match `payloadHash`, then verify RSA-PSS-SHA256 of `signature` against `operatorPublicKey`.",
        "properties": {
          "version": { "type": "integer", "enum": [1] },
          "type": { "type": "string", "enum": ["verify.bundle.run"] },
          "jobId": { "type": "string" },
          "runId": { "type": "string" },
          "tenantId": { "type": "string" },
          "operator": {
            "type": "string",
            "nullable": true,
            "description": "Arweave wallet address"
          },
          "operatorPublicKey": { "type": "string", "nullable": true },
          "gateway": { "type": "string", "nullable": true },
          "startedAt": { "type": "string", "format": "date-time" },
          "finishedAt": { "type": "string", "format": "date-time" },
          "input": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["txIds"] },
              "ids": { "type": "array", "items": { "type": "string" } }
            }
          },
          "totals": {
            "type": "object",
            "properties": {
              "verified": { "type": "integer" },
              "tampered": { "type": "integer" },
              "unavailable": { "type": "integer" },
              "cacheHit": { "type": "integer" },
              "bytesFetched": { "type": "integer" },
              "total": { "type": "integer" }
            }
          },
          "deltas": {
            "nullable": true,
            "type": "object",
            "description": "Diffs vs the previous run for this job. Always null until scheduled jobs ship (post-MVP).",
            "properties": {
              "verified": { "type": "integer" },
              "tampered": { "type": "integer" },
              "unavailable": { "type": "integer" }
            }
          },
          "failures": {
            "type": "array",
            "description": "Failed-tx detail, capped at 1000 entries. Beyond the cap, query /jobs/:id/results.",
            "items": { "$ref": "#/components/schemas/JobResult" }
          },
          "failuresTruncated": { "type": "boolean" },
          "payloadHash": {
            "type": "string",
            "description": "SHA-256 (base64url) of canonical bundle minus signature and payloadHash fields"
          },
          "signature": {
            "type": "string",
            "nullable": true,
            "description": "RSA-PSS-SHA256 signature (base64url). Null if no operator wallet is configured."
          }
        }
      }
    }
  },
  "tags": [
    { "name": "Verification", "description": "Verify Arweave transaction data" },
    { "name": "Attestation", "description": "Signed certificates and attestation data" },
    {
      "name": "Jobs",
      "description": "Bulk verification jobs, results, signed bundles, and events"
    },
    { "name": "System", "description": "Health checks and service info" }
  ]
}
